{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "2nd-brain-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "rules": [
    // Bundle markdown docs as string imports so resources.ts can serve
    // them verbatim without duplicating the content in TS source. Path
    // resolution follows the import string from the importing module
    // (e.g. ../../docs/foo.md from src/resources.ts).
    { "type": "Text", "globs": ["**/*.md"], "fallthrough": false }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "f38c11ac89704b7396d469cb0a0db889"
    }
  ]
  // Secrets set via CF dashboard (Workers & Pages → 2nd-brain-mcp → Settings → Variables):
  //   BRAIN_MCP_TOKEN   — bearer token for MCP clients
  //   OPENAI_API_KEY    — for query embeddings in search_brain
  //   BRAIN_USER_ID     — text id used by existing entries (e.g. Telegram numeric id "236871164")
}
